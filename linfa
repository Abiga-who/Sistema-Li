<html lang="es"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Atlas Interactivo del Sistema Linfático</title><link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"><style>:root {  --primary-purple: #b39cd0;  --primary-blue: #a2d2ff;  --bg-soft: #f8f9ff;  --text-main: #4a4e69;  --white: #ffffff;  --active-color: #6c5ce7;}
body { background: var(--bg-soft); color: var(--text-main); font-family: 'DM Sans', sans-serif; margin: 0; padding-top: 80px; line-height: 1.6; }nav { position: fixed; top: 0; width: 100%; background: white; height: 65px; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 15px rgba(0,0,0,0.05); z-index: 100; }.nav-logo { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; font-weight: 600; color: var(--primary-purple); text-decoration: none; cursor: pointer; }
.container { max-width: 1200px; margin: 0 auto; padding: 20px; display: flex; flex-direction: column; gap: 30px; }
.health-controls { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }.big-btn { padding: 25px; border-radius: 20px; border: 2px solid var(--primary-purple); background: white; cursor: pointer; font-family: 'Cormorant Garamond', serif; font-size: 1.7rem; color: var(--primary-purple); font-weight: 600; transition: 0.3s ease; box-shadow: 0 5px 15px rgba(179,156,208,0.15); }.big-btn:hover { background: var(--primary-purple); color: white; transform: translateY(-5px); }
.info-panel { background: white; border-radius: 25px; padding: 40px; border-left: 12px solid var(--primary-purple); box-shadow: 0 15px 40px rgba(0,0,0,0.05); min-height: 380px; transition: 0.5s; }.panel-badge { background: #e2eafc; color: var(--primary-purple); padding: 6px 18px; border-radius: 20px; font-size: 0.9rem; font-weight: 600; text-transform: uppercase; }.info-panel h3 { font-family: 'Cormorant Garamond', serif; font-size: 2.5rem; margin: 15px 0; font-weight: 400; color: #333; }.info-panel p { font-size: 1.15rem; margin-bottom: 20px; }
.dynamic-box { padding: 20px; border-radius: 15px; margin-top: 15px; display: none; animation: slideUp 0.4s ease; }.rel-box { background: #f0f4ff; border-left: 5px solid var(--primary-blue); }.care-box { background: #eafbea; border-left: 5px solid #84cc84; }.risk-box { background: #fee2e2; border-left: 5px solid #ef4444; }
@keyframes slideUp { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }
.map-layout { display: grid; grid-template-columns: 1fr 340px 1fr; gap: 20px; align-items: start; }
@media (max-width: 900px) { .map-layout { grid-template-columns: 1fr; } .map-legend { order: 2; } .body-wrapper { order: 1; max-width: 400px; margin: 0 auto; } .info-panel h3 { font-size: 2rem; } .health-controls { grid-template-columns: 1fr; } }
.map-legend { display: flex; flex-direction: column; gap: 10px; }.legend-btn { background: white; border: 1px solid #eee; padding: 15px; border-radius: 12px; cursor: pointer; width: 100%; text-align: left; transition: 0.3s; font-size: 0.95rem; }.legend-btn:hover { border-color: var(--primary-purple); color: var(--primary-purple); padding-left: 20px; background: #faf8ff; }
.legend-btn.active-btn { background: var(--active-color); color: white; border-color: var(--active-color); }
.body-wrapper { position: relative; border-radius: 25px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.1); background: white; }.main-img { display: block; width: 100%; height: auto; }.spot { position: absolute; width: 18px; height: 18px; background: rgba(162, 210, 255, 0.7); border: 2px solid white; border-radius: 50%; cursor: pointer; transform: translate(-50%, -50%); transition: 0.3s; z-index: 10; }.spot:hover, .spot.active-spot { background: var(--active-color); transform: translate(-50%, -50%) scale(1.4); box-shadow: 0 0 15px var(--active-color); }
.hidden { display: none; }</style></head><body>
<nav><a class="nav-logo" onclick="show('que-es')">Atlas Interactivo del Sistema Linfático</a></nav>
<div class="container">    <div class="health-controls">        <button class="big-btn" onclick="show('care')">¿Cómo puedo cuidarlo?</button>        <button class="big-btn" onclick="show('damage')">¿Qué pasa si no lo cuido?</button>    </div>
    <div class="info-panel" id="panel">        <div id="welcome" style="text-align: center; padding-top: 3rem;">            <h3 style="color: #ccc; font-style: italic; font-weight: 400;">Haz clic en un botón o en el esquema para explorar</h3>        </div>        <div id="info" class="hidden">            <span class="panel-badge" id="tag">Categoría</span>            <h3 id="title">Título</h3>            <p id="desc">Descripción detallada...</p>            <div id="rel" class="dynamic-box rel-box"></div>            <div id="care" class="dynamic-box care-box"></div>            <div id="risk" class="dynamic-box risk-box"></div>        </div>    </div>
    <div class="map-layout">        <div class="map-legend">            <button class="legend-btn" data-id="amigdalas" onclick="show('amigdalas')">Amígdalas</button>            <button class="legend-btn" data-id="cervicales" onclick="show('cervicales')">Cervicales</button>            <button class="legend-btn" data-id="axilares" onclick="show('axilares')">Axilares pectorales</button>            <button class="legend-btn" data-id="epitroqueal" onclick="show('epitroqueal')">Epitroqueal braquial</button>            <button class="legend-btn" data-id="conducto" onclick="show('conducto')">Conducto Torácico</button>            <button class="legend-btn" data-id="apendice" onclick="show('apendice')">Apéndice</button>            <button class="legend-btn" data-id="inguinales" onclick="show('inguinales')">Inguinales</button>            <button class="legend-btn" data-id="popliteos" onclick="show('popliteos')">Poplíteos</button>        </div>                <div class="body-wrapper">            <img src="https://i.postimg.cc/LstWtrbs/sis-linfa.jpg" alt="Mapa Linfático Completo" class="main-img">                        <div class="spot" data-id="amigdalas" style="top:9%; left:53%" onclick="show('amigdalas')"></div>            <div class="spot" data-id="cervicales" style="top:14%; left:45%" onclick="show('cervicales')"></div>            <div class="spot" data-id="timo" style="top:22%; left:51%" onclick="show('timo')"></div>            <div class="spot" data-id="axilares" style="top:26%; left:36%" onclick="show('axilares')"></div>            <div class="spot" data-id="bazo" style="top:34%; left:55%" onclick="show('bazo')"></div>            <div class="spot" data-id="epitroqueal" style="top:37%; left:28%" onclick="show('epitroqueal')"></div>            <div class="spot" data-id="conducto" style="top:34%; left:47%" onclick="show('conducto')"></div>            <div class="spot" data-id="placas" style="top:47%; left:53%" onclick="show('placas')"></div>            <div class="spot" data-id="apendice" style="top:48%; left:42%" onclick="show('apendice')"></div>            <div class="spot" data-id="inguinales" style="top:57%; left:43%" onclick="show('inguinales')"></div>            <div class="spot" data-id="medula" style="top:57%; left:58%" onclick="show('medula')"></div>            <div class="spot" data-id="popliteos" style="top:71%; left:38%" onclick="show('popliteos')"></div>            <div class="spot" data-id="vasos" style="top:87%; left:60%" onclick="show('vasos')"></div>        </div>
        <div class="map-legend">            <button class="legend-btn" data-id="timo" onclick="show('timo')">Timo</button>            <button class="legend-btn" data-id="bazo" onclick="show('bazo')">Bazo</button>            <button class="legend-btn" data-id="placas" onclick="show('placas')">Placas de Peyer</button>            <button class="legend-btn" data-id="medula" onclick="show('medula')">Médula ósea</button>            <button class="legend-btn" data-id="vasos" onclick="show('vasos')">Vasos linfáticos</button>        </div>    </div></div>
<script>const db = {
    "que-es": { t: "¿Qué es el Sistema Linfático?", g: "Anatomía y Fisiología", d: "Es una red vascular y orgánica esencial que forma parte del sistema circulatorio y del sistema inmunitario. Se compone de linfa (exceso de líquido intersticial), vasos linfáticos, ganglios, y órganos especializados. Sus funciones principales son el drenaje de líquido de los tejidos para evitar edemas, el transporte de grasas absorbidas en el intestino delgado (quilo) y la producción y maduración de glóbulos blancos para la defensa biológica.", r: "Homeostasis de fluidos y vigilancia inmunitaria constante." },
    amigdalas: { t: "Amígdalas (Anillo de Waldeyer)", g: "Tejido Linfoide", d: "Estructuras situadas en la entrada de la orofaringe y nasofaringe. Contienen criptas que atrapan antígenos ambientales. Su función principal es la síntesis de inmunoglobulinas y la activación de linfocitos ante patógenos que ingresan por las vías aéreas o digestivas.", r: "Barrera protectora respiratoria superior." },
    cervicales: { t: "Ganglios Cervicales", g: "Red de Filtrado", d: "Ubicados a lo largo de los músculos del cuello. Se dividen en superficiales y profundos. Reciben linfa de la lengua, laringe, tiroides y cuero cabelludo. Son el principal sitio de respuesta inmune ante infecciones dentales, otitis y procesos virales respiratorios.", r: "Centinelas de la región craneofacial." },
    axilares: { t: "Ganglios Axilares Pectorales", g: "Complejo Linfático Torácico", d: "Grupo de 20 a 30 ganglios organizados en niveles. Reciben el 75% del drenaje linfático de la mama, además del brazo y la pared torácica lateral. Son fundamentales en la estadificación de enfermedades oncológicas y en el mantenimiento de la presión de fluidos del torso superior.", r: "Drenaje mamario y de extremidades superiores." },
    epitroqueal: { t: "Nódulo Epitroqueal", g: "Filtro Periférico", d: "Pequeño nódulo linfático palpable por encima del epicóndilo medial del húmero. Filtra la linfa que proviene de los dedos meñique y anular, así como de la parte medial del antebrazo, actuando como primera línea de defensa antes de los ganglios axilares.", r: "Respuesta inmune local del antebrazo." },
    conducto: { t: "Conducto Torácico", g: "Vía de Retorno Sistémico", d: "Se origina en la cisterna del quilo (abdomen) y asciende por el tórax. Es el colector linfático más importante, devolviendo hasta 4 litros de linfa al día a la circulación sanguínea a través del ángulo venoso yugulosubclavio izquierdo. Transporta lípidos absorbidos en el sistema digestivo.", r: "Conexión crítica entre sistema linfático y venoso." },
    apendice: { t: "Apéndice Vermiforme", g: "Órgano Inmuno-Digestivo", d: "Estructura tubular rica en folículos linfoides GALT (tejido linfoide asociado al intestino). Sirve como 'bio-reserva' para la microbiota comensal y ayuda en la maduración de linfocitos B y la producción de anticuerpos IgA, protegiendo contra invasiones patógenas en el colon.", r: "Inmunidad mucosa y salud intestinal." },
    inguinales: { t: "Ganglios Inguinales", g: "Estación de Filtrado Pélvico", d: "Cadena de ganglios en el triángulo de Scarpa. Drenan la linfa de la pared abdominal infraumbilical, glúteos, órganos genitales externos y los miembros inferiores completos. Su inflamación es clave para diagnosticar patologías pélvicas o de extremidades.", r: "Control de infecciones de la mitad inferior del cuerpo." },
    popliteos: { t: "Nódulos Poplíteos", g: "Filtro Articular", d: "Situados profundamente en la fosa poplítea detrás de la rodilla. Reciben linfa de los vasos linfáticos que acompañan a las venas profundas de la pierna y de la piel de la parte lateral del pie y talón. Son esenciales para el drenaje de la articulación de la rodilla.", r: "Gestión de fluidos de la pierna y pie." },
    timo: { t: "Timo", g: "Órgano Linfoide Primario", d: "Situado en el mediastino superior. Es el sitio de diferenciación y selección de linfocitos T. Aquí, las células T progenitoras se transforman en células T cooperadoras (CD4) o citotóxicas (CD8). Atrofia gradualmente después de la pubertad, pero mantiene función inmunitaria de por vida.", r: "Entrenamiento del ejército celular de defensa." },
    bazo: { t: "Bazo (Esplenio)", g: "Órgano Linfoide Secundario", d: "Localizado en el hipocondrio izquierdo. Tiene 'pulpa blanca' (tejido linfático) para defensa contra antígenos sanguíneos y 'pulpa roja' para filtrar eritrocitos viejos o dañados. Almacena monocitos y plaquetas, liberándolos en caso de emergencia circulatoria.", r: "Limpieza hemática y respuesta inmune sistémica." },
    placas: { t: "Placas de Peyer", g: "Tejido Linfoide MALT", d: "Cúmulos de tejido linfático situados en la lámina propia de la mucosa del intestino delgado. Contienen células M que transportan antígenos desde la luz intestinal hacia los linfocitos, permitiendo una respuesta inmune rápida ante patógenos ingeridos.", r: "Vigilancia inmunológica del tracto digestivo." },
    medula: { t: "Médula Ósea", g: "Tejido Hematopoyético", d: "Ubicada en el interior de los huesos planos y epífisis de huesos largos. Es el lugar donde ocurre la hematopoyesis (creación de todas las células sanguíneas). Los linfocitos B maduran completamente aquí antes de migrar a los ganglios linfáticos y bazo.", r: "Fábrica vital de células inmunitarias y sanguíneas." },
    vasos: { t: "Vasos Linfáticos", g: "Canales de Transporte", d: "Red de conductos con paredes delgadas y numerosas válvulas semilunares que aseguran el flujo unidireccional. Se dividen en capilares, colectores y troncos. Utilizan la contracción de los músculos esqueléticos y los cambios de presión torácica para movilizar la linfa.", r: "Red de transporte de desechos y nutrientes lipídicos." },
    care: { t: "Plan de Cuidado Linfático", g: "Salud Preventiva", d: "A diferencia del sistema circulatorio, el linfático no posee bomba cardíaca; su eficiencia depende de factores externos controlables.", c: "• Hidratación: El agua es el solvente base de la linfa; la deshidratación espesa el fluido. • Actividad Física: La contracción muscular es el motor principal de los vasos linfáticos. • Respiración Diafragmática: Los cambios de presión en el tórax succionan la linfa hacia arriba. • Control de Sodio: El exceso de sal retiene líquidos intersticiales, sobrecargando el sistema." },
    damage: { t: "Patologías y Consecuencias", g: "Disfunción Sistémica", d: "Un fallo en el transporte linfático compromete la integridad tisular y la respuesta defensiva.", k: "• Linfedema Primario/Secundario: Acumulación de líquido rico en proteínas, causando fibrosis. • Linfangitis: Inflamación aguda de los vasos, usualmente por infección bacteriana. • Compromiso Inmune: Retraso en la detección de patógenos, aumentando la severidad de enfermedades infecciosas." }
};

function show(id) {
    const item = db[id];
    document.getElementById('welcome').classList.add('hidden');
    document.getElementById('info').classList.remove('hidden');
    document.getElementById('title').innerText = item.t;
    document.getElementById('tag').innerText = item.g;
    document.getElementById('desc').innerText = item.d;
        
    const r = document.getElementById('rel'); r.style.display = item.r ? "block" : "none";
    if(item.r) r.innerHTML = "<strong>Explicación Fisiológica:</strong> " + item.r;
        
    const c = document.getElementById('care'); c.style.display = item.c ? "block" : "none";
    if(item.c) c.innerHTML = "<strong>Guía de Cuidado Integral:</strong><br>" + item.c;
        
    const k = document.getElementById('risk'); k.style.display = item.k ? "block" : "none";
    if(item.k) k.innerHTML = "<strong>Manifestaciones de Patología:</strong><br>" + item.k;

    document.querySelectorAll('.legend-btn, .spot').forEach(el => {
        el.classList.remove('active-btn', 'active-spot');
        if(el.getAttribute('data-id') === id) {
            el.classList.add(el.classList.contains('spot') ? 'active-spot' : 'active-btn');
        }
    });
    
    if(window.innerWidth < 900) {
        document.getElementById('panel').scrollIntoView({behavior: 'smooth'});
    }
}</script></body></html>
